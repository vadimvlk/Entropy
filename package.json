    "test:e2e": "node test/e2e.mjs"
  },
  "dependencies": {
    "lightweight-charts": "^5.0.8"
  },
  "devDependencies": {
    "playwright": "^1.61.0",
    "typescript": "^5.7.2",
    "vite": "^6.3.5"
  }
}
